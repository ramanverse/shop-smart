{
    "family": "shop-smart-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "server",
            "image": "<AWS_ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/shop-smart-server:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3100,
                    "hostPort": 3100,
                    "protocol": "tcp"
                }
            ],
            "healthCheck": {
                "command": ["CMD-SHELL", "curl -f http://localhost:3100/api/health || exit 1"],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            },
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/shop-smart",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "server"
                }
            }
        },
        {
            "name": "client",
            "image": "<AWS_ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/shop-smart-client:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "healthCheck": {
                "command": ["CMD-SHELL", "curl -f http://localhost/ || exit 1"],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            },
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/shop-smart",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "client"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/LabRole",
    "taskRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/LabRole"
}
# AWS Academy Deployment Verified
